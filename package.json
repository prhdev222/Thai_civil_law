{
  "name": "civil-law-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:vercel": "vercel --prod",
    "db:create": "turso db create civil-law-db",
    "db:migrate": "turso db shell civil-law-db < migrations/001_init.sql",
